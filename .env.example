# Base URL of the local Focalboard instance
FOCALBOARD_URL=http://localhost:8000

# Authentication token for API access
FOCALBOARD_TOKEN=YFOCALBOARD_TOKEN

# Target board id
BOARD_ID=BOARD_ID

# Parent block id under which new cards are created
PARENT_ID=PARENT_BLOCK_ID

# Property id used for status
STATUS_PROP_ID=STATUS_PROPERTY_ID

# Property id used for priority
PRIORITY_PROP_ID=RIORITY_PROPERTY_ID

# Option id for To do status
STATUS_TODO_ID=STATUS_TODO_OPTION_ID

# Option id for In Progress status
STATUS_PROGRESS_ID=STATUS_PROGRESS_OPTION_ID

# Option id for Done status
STATUS_DONE_ID=STATUS_DONE_OPTION_ID

# Option id for High priority
PRIORITY_HIGH_ID=PRIORITY_HIGH_OPTION_ID

# Option id for Medium priority
PRIORITY_MEDIUM_ID=PRIORITY_MEDIUM_OPTION_ID

# Option id for Low priority
PRIORITY_LOW_ID=PRIORITY_LOW_OPTION_ID